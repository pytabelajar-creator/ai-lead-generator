# Database
DATABASE_URL="postgresql://leadgen:leadgen_secret@localhost:5432/leadgen?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=7d

# Encryption (for API keys at rest)
ENCRYPTION_KEY=change-this-to-a-random-32-byte-hex-string

# API
API_HOST=0.0.0.0
API_PORT=3001

# Worker
WORKER_CONCURRENCY=2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# SMTP Email (optional - if not set, email opens mailto: client-side)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_PROVIDER=gmail

# Twilio WhatsApp (optional - if not set, WhatsApp opens wa.me client-side)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=+1234567890
